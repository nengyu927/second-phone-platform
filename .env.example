# 此檔僅提供欄位範例。setup.ps1 會建立不提交 Git 的 .env。
DB_URL=jdbc:mysql://localhost:3306/second_phone_platform?useSSL=false&serverTimezone=Asia/Taipei&characterEncoding=utf8
DB_USERNAME=root
DB_PASSWORD=
APP_JWT_SECRET=GENERATE_A_LOCAL_SECRET_DURING_SETUP
APP_JWT_EXPIRATION_MS=86400000
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=
APP_UPLOAD_DIR=uploads
SERVER_PORT=8080
